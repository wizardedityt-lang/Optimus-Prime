	do local row=mkRow(28);mkLabel(row,"Lagger Carry");laggerCarryBox=mkBox(row,LAGGER_CARRY_SPEED,45,55,function(v) if v>0 and v<=500 then LAGGER_CARRY_SPEED=v end;saveConfig() end) end

