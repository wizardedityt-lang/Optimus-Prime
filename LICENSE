	do local row=mkRow(28);mkLabel(row,"Aimbot Vertical Speed");mkBox(row,AUTO_BAT_VERT_SPEED,45,55,function(v) if v>0 and v<=200 then AUTO_BAT_VERT_SPEED=v end;saveConfig() end) end
